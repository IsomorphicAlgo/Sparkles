# -----------------------------------------------------------------------------
# Secrets and credentials (never commit)
# -----------------------------------------------------------------------------
.env
.env.*
!.env.example
.envrc
secrets*.yaml
secrets*.yml
secrets*.json
*credentials*.json
client_secret*.json
token.json
token.pickle
*.pem
*.p12
id_rsa
id_ecdsa
id_ed25519

# -----------------------------------------------------------------------------
# Python bytecode, packaging, virtual environments
# -----------------------------------------------------------------------------
__pycache__/
*.py[cod]
*$py.class
.Python
.venv/
venv/
env/
.env.venv/
*.egg-info/
.eggs/
dist/
build/
pip-wheel-metadata/
*.egg

# -----------------------------------------------------------------------------
# Local data, caches, and training outputs (regenerate from CLI)
# -----------------------------------------------------------------------------
data/cache/
# Personal trade CSVs (see data/journal/README.md; example: configs/examples/)
data/journal/*.csv
artifacts/
*.parquet

# -----------------------------------------------------------------------------
# Test, type-check, and linter caches
# -----------------------------------------------------------------------------
.pytest_cache/
.mypy_cache/
.ruff_cache/
.coverage
.coverage.*
coverage.xml
htmlcov/
.tox/
.nox/
.hypothesis/

# -----------------------------------------------------------------------------
# Optional future tooling (harmless if unused)
# -----------------------------------------------------------------------------
mlruns/
wandb/

# -----------------------------------------------------------------------------
# IDE / OS noise
# -----------------------------------------------------------------------------
.idea/
*.swp
*.swo
*~
.DS_Store
Thumbs.db
Desktop.ini

